# ── Choose a backend ────────────────────────────────────────────────
# inference | litellm | openai | transformers
CARTOGRAPHER_MODEL_TYPE=inference

# --- Option A: Hugging Face Inference (default) ---
HF_TOKEN=hf_xxx
# CARTOGRAPHER_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct
# CARTOGRAPHER_PROVIDER=together

# --- Option B: LiteLLM (Anthropic / OpenAI / Gemini / ...) ---
# CARTOGRAPHER_MODEL_TYPE=litellm
# CARTOGRAPHER_MODEL_ID=anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- Option C: any OpenAI-compatible server ---
# CARTOGRAPHER_MODEL_TYPE=openai
# CARTOGRAPHER_MODEL_ID=gpt-4o
# CARTOGRAPHER_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxx
